                <Button icon={<EyeRegular />} appearance="subtle" onClick={() => handleView(item)}>
                    {t("view")}
                </Button>
            ),
        }),
    ];

    return (
        <div dir={isRTL ? "rtl" : "ltr"} className={styles.page}>
            <div className={styles.shell}>
                {message && (
                    <MessageBar intent="warning">
                        <MessageBarBody>{message}</MessageBarBody>
                    </MessageBar>
                )}
                {view === "list" ? (
                    <MainChecklistList
                        columns={columns}
                        checklists={filteredChecklists}
                        filterType={filterType}
                        setFilterType={setFilterType}
                        filterTarget={filterTarget}
                        setFilterTarget={setFilterTarget}
                        onAdd={() => {
                            setEditingChecklist(null);
                            setViewingChecklist(null);
                            setView("editor");
                        }}
                        t={t}
                        isLoading={isLoading}
                    />
                ) : view === "details" && viewingChecklist ? (
                    <ChecklistDetails
                        checklist={viewingChecklist}
                        versions={getChecklistVersions(checklists, viewingChecklist)}
                        onBack={() => setView("list")}
                        t={t}
                    />
                ) : (
                    <ChecklistEditor
                        checklist={editingChecklist}
                        onBack={() => setView("list")}
                        onSave={handleSaveChecklist}
                        requireReviewForNewVersion={requireReviewForNewVersion}
                        t={t}
                    />
                )}
            </div>
        </div>
    );
};

