function getUiLanguageId() {
    return (
        (typeof Xrm !== "undefined" &&
            Xrm.Utility?.getGlobalContext()?.userSettings?.languageId) ||
        1033
    );
}

function getLanguageAndRtl() {
    const uiLanguageId = getUiLanguageId();
    const lang = langMap[uiLanguageId]?.code || "en-US";
    const isRtl = langMap[uiLanguageId]?.isRtl ?? false;
    return { language: lang, isRTL: isRtl };
}

function getTranslationFn(language: string) {
    return (key: string): string =>
        translations[language]?.[key] || translations["en-US"]?.[key] || key;
}

function hasDataverse() {
    return typeof Xrm !== "undefined" && !!Xrm.WebApi?.retrieveMultipleRecords;
}

function canSaveDataverse() {
    return typeof Xrm !== "undefined" && !!Xrm.WebApi?.createRecord && !!Xrm.WebApi?.updateRecord;
}

function parseBooleanSetting(value: unknown, fallback: boolean) {
    if (value === undefined || value === null || value === "") return fallback;
    const normalized = String(value).trim().toLowerCase();
    if (["true", "yes", "y", "1"].includes(normalized)) return true;
    if (["false", "no", "n", "0"].includes(normalized)) return false;
    return fallback;
}

async function loadRequireReviewForNewVersions(): Promise<boolean> {
    if (typeof Xrm === "undefined") return true;

    try {
        const globalContext = Xrm.Utility?.getGlobalContext?.();
        const appSettingValue = globalContext?.getCurrentAppSetting?.(REQUIRE_REVIEW_SETTING_NAME);
        return parseBooleanSetting(appSettingValue, true);
    } catch {
        return true;
    }
}

function getValue(record: Record<string, any>, names: string[], fallback = "") {
    for (const name of names) {
        if (record[name] !== undefined && record[name] !== null) return record[name];
        const formatted = `${name}@OData.Community.Display.V1.FormattedValue`;
        if (record[formatted] !== undefined && record[formatted] !== null) return record[formatted];
    }
    return fallback;
}

function getDisplayValue(record: Record<string, any>, names: string[], fallback = "") {
    for (const name of names) {
        const formatted = `${name}@OData.Community.Display.V1.FormattedValue`;
        if (record[formatted] !== undefined && record[formatted] !== null) return record[formatted];
        if (record[name] !== undefined && record[name] !== null) return record[name];
    }
    return fallback;
}

function makeId() {
    if (typeof crypto !== "undefined" && "randomUUID" in crypto) {
        return (crypto as any).randomUUID();
    }
    return Math.random().toString(36).slice(2, 11);
}

function normalizeSections(sections: any[]): ChecklistSection[] {
    return sections.map((section) => ({
        id: String(section.id || section.int_checklistsectionid || makeId()),
        name: String(section.name || section.int_name || ""),
        bulkServiceable: Boolean(section.bulkServiceable || section.int_bulkserviceable),
        parentId: section.parentId || section.int_parentsectionid || null,
        sections: normalizeSections(Array.isArray(section.sections) ? section.sections : []),
        items: normalizeItems(Array.isArray(section.items) ? section.items : []),
    }));
}

function normalizeItems(items: any[]): ChecklistItem[] {
    return items.map((item) => ({
        id: String(item.id || item.int_checklistitemid || makeId()),
        name: String(item.name || item.int_name || ""),
        description: String(item.description || item.int_description || ""),
        quantity: Number(item.quantity || item.int_quantity || 1),
    }));
}

function parseSections(value: unknown): ChecklistSection[] {
    if (!value || typeof value !== "string") return [];
    try {
        const parsed = JSON.parse(value);
        const source = Array.isArray(parsed) ? parsed : parsed.sections;
        return Array.isArray(source) ? normalizeSections(source) : [];
    } catch {
        return [];
    }
}

function mapChecklistRecord(record: Record<string, any>): Checklist {
    const definitionJson = String(
        getValue(record, ["int_definitionjson", "int_definition", "definitionjson"], "")
    );
    return {
        id: String(getValue(record, ["int_checklistid", "id", "checklistid"], "")),
        name: String(getValue(record, ["int_name", "name", "int_checklistname"], "Untitled checklist")),
        currentVersion: String(getValue(record, ["int_currentversion", "int_version", "currentversion"], "1")),
        checklistType: String(getDisplayValue(record, ["int_checklisttype", "checklisttype"], "Standard")),
        targetType: String(getDisplayValue(record, ["int_targettype", "targettype"], "")),
        statuscode: Number(getValue(record, ["statuscode"], 1)),
        sections: parseSections(definitionJson),
        definitionJson,
        definitionHash: String(getValue(record, ["int_definitionhash", "definitionhash"], "")),
        raw: record,
    };
}

async function loadChecklistsFromDataverse(): Promise<Checklist[]> {
    const result = await Xrm.WebApi.retrieveMultipleRecords(TABLE_NAME, "?$top=5000");
    return (result.entities || []).map(mapChecklistRecord);
}

function buildDataversePayload(checklist: Checklist) {
    const definitionJson = checklist.definitionJson || JSON.stringify({ sections: checklist.sections });
    return {
        int_name: checklist.name,
        int_currentversion: checklist.currentVersion,
        int_checklisttype: checklist.checklistType,
        int_targettype: checklist.targetType,
        statuscode: checklist.statuscode,
        int_definitionjson: definitionJson,
        int_definitionhash: checklist.definitionHash || hashText(definitionJson),
    };
}

async function saveChecklistToDataverse(checklist: Checklist, createNewRecord: boolean) {
    const payload = buildDataversePayload(checklist);
    if (checklist.id && !createNewRecord) {
        await Xrm.WebApi.updateRecord(TABLE_NAME, checklist.id, payload);
        return checklist;
    }
    const created = await Xrm.WebApi.createRecord(TABLE_NAME, payload);
    return { ...checklist, id: created.id };
}

function hashText(text: string) {
    let hash = 0;
    for (let i = 0; i < text.length; i++) {
        hash = (hash << 5) - hash + text.charCodeAt(i);
        hash |= 0;
    }
    return Math.abs(hash).toString(16);
}

function getChecklistFamilyKey(checklist: Checklist) {
    return [checklist.name.trim().toLowerCase(), checklist.checklistType, checklist.targetType || ""].join("|");
}

function getChecklistVersions(checklists: Checklist[], checklist: Checklist) {
    const familyKey = getChecklistFamilyKey(checklist);
    return checklists
        .filter((candidate) => getChecklistFamilyKey(candidate) === familyKey)
        .sort((a, b) => Number(b.currentVersion) - Number(a.currentVersion));
}

function getLatestChecklists(checklists: Checklist[]) {
    const latestByFamily = new Map<string, Checklist>();
    checklists.forEach((checklist) => {
        const familyKey = getChecklistFamilyKey(checklist);
        const currentLatest = latestByFamily.get(familyKey);
        if (!currentLatest || Number(checklist.currentVersion) > Number(currentLatest.currentVersion)) {
            latestByFamily.set(familyKey, checklist);
        }
    });
    return Array.from(latestByFamily.values()).sort((a, b) => a.name.localeCompare(b.name));
}

function findSectionById(sections: ChecklistSection[], sectionId?: string): ChecklistSection | undefined {
    if (!sectionId) return undefined;
    for (const section of sections) {
        if (section.id === sectionId) return section;
        const child = findSectionById(section.sections, sectionId);
        if (child) return child;
    }
    return undefined;
}

function findFirstLeafSection(sections: ChecklistSection[]): ChecklistSection | undefined {
    for (const section of sections) {
        const childLeaf = findFirstLeafSection(section.sections);
        if (childLeaf) return childLeaf;
        if (section.sections.length === 0) return section;
    }
    return undefined;
}

const GeneratedComponent = () => {
    const styles = useStyles();
    const { language, isRTL } = useMemo(getLanguageAndRtl, []);
    const t = useMemo(() => getTranslationFn(language), [language]);

    const [view, setView] = useState<"list" | "details" | "editor">("list");
    const [editingChecklist, setEditingChecklist] = useState<Checklist | null>(null);
    const [viewingChecklist, setViewingChecklist] = useState<Checklist | null>(null);
    const [filterType, setFilterType] = useState<string | undefined>();
    const [filterTarget, setFilterTarget] = useState<string | undefined>();
    const [checklists, setChecklists] = useState<Checklist[]>(EMPTY_CHECKLISTS);
    const [isLoading, setIsLoading] = useState(true);
    const [message, setMessage] = useState("");
    const [requireReviewForNewVersion, setRequireReviewForNewVersion] = useState(true);

    useEffect(() => {
        let isMounted = true;
        async function load() {
            setIsLoading(true);
            try {
                if (hasDataverse()) {
                    const [rows, requireReview] = await Promise.all([
                        loadChecklistsFromDataverse(),
                        loadRequireReviewForNewVersions(),
                    ]);
                    if (isMounted) setChecklists(rows);
                    if (isMounted) setRequireReviewForNewVersion(requireReview);
                } else if (isMounted) {
                    setMessage(t("loadFallback"));
                    setChecklists(EMPTY_CHECKLISTS);
                    setRequireReviewForNewVersion(true);
                }
            } catch (error) {
                if (isMounted) {
                    setMessage(error instanceof Error ? error.message : t("loadFallback"));
                    setChecklists(EMPTY_CHECKLISTS);
                }
            } finally {
                if (isMounted) setIsLoading(false);
            }
        }
        load();
        return () => {
            isMounted = false;
        };
    }, [t]);

    const filteredChecklists = useMemo(
        () =>
            getLatestChecklists(checklists).filter((c) => {
                if (filterType && c.checklistType !== filterType) return false;
                if (filterType === "Standard" && filterTarget && c.targetType !== filterTarget) {
                    return false;
                }
                return true;
            }),
        [checklists, filterTarget, filterType]
    );

    const handleView = (checklist: Checklist) => {
        setViewingChecklist(checklist);
        setEditingChecklist(null);
        setView("details");
    };

    const handleSaveChecklist = async (newChecklist: Checklist, isNew: boolean, publishAction: "draft" | "submit") => {
        try {
            const createsNewVersion = isNew || !!newChecklist.id;
            const statuscode =
                publishAction === "draft"
                    ? STATUS_DRAFT
                    : requireReviewForNewVersion
                        ? STATUS_IN_REVIEW
                        : STATUS_PUBLISHED;
            const checklistToSave = { ...newChecklist, statuscode };
            const savedChecklist = canSaveDataverse()
                ? await saveChecklistToDataverse(checklistToSave, createsNewVersion)
                : { ...checklistToSave, id: createsNewVersion ? makeId() : checklistToSave.id };
            setChecklists((prev) =>
                createsNewVersion
                    ? [...prev, { ...savedChecklist, id: savedChecklist.id || makeId() }]
                    : prev.map((c) => (c.id === savedChecklist.id ? savedChecklist : c))
            );
            if (!canSaveDataverse()) setMessage(t("saveFallback"));
            setView("list");
        } catch (error) {
            setMessage(error instanceof Error ? error.message : t("saveFallback"));
        }
    };

    const columns = [
        createTableColumn<Checklist>({
            columnId: "name",
            renderHeaderCell: () => <Text weight="semibold">{t("checklistName")}</Text>,
            renderCell: (item) => <TableCellLayout>{item.name}</TableCellLayout>,
        }),
        createTableColumn<Checklist>({
            columnId: "currentVersion",
            renderHeaderCell: () => <Text weight="semibold">{t("currentVersion")}</Text>,
            renderCell: (item) => <TableCellLayout>{item.currentVersion}</TableCellLayout>,
        }),
        createTableColumn<Checklist>({
            columnId: "checklistType",
            renderHeaderCell: () => <Text weight="semibold">{t("checklistType")}</Text>,
            renderCell: (item) => <TableCellLayout>{item.checklistType}</TableCellLayout>,
        }),
        createTableColumn<Checklist>({
            columnId: "targetType",
            renderHeaderCell: () => <Text weight="semibold">{t("checklistTargetType")}</Text>,
            renderCell: (item) => <TableCellLayout>{item.targetType}</TableCellLayout>,
        }),
        createTableColumn<Checklist>({
            columnId: "statuscode",
            renderHeaderCell: () => <Text weight="semibold">{t("status")}</Text>,
            renderCell: (item) => {
                const status = STATUS_CODES.find((s) => s.key === item.statuscode);
                return (
                    <TableCellLayout>
                        <Badge appearance={status?.appearance || "outline"}>{status?.text || item.statuscode}</Badge>
                    </TableCellLayout>
