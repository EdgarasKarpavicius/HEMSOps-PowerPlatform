function ChecklistEditor({
    checklist,
    onBack,
    onSave,
    requireReviewForNewVersion,
    t,
}: {
    checklist: Checklist | null;
    onBack: () => void;
    onSave: (c: Checklist, isNew: boolean, publishAction: "draft" | "submit") => void;
    requireReviewForNewVersion: boolean;
    t: (key: string) => string;
}) {
    const styles = useStyles();
    const isNew = !checklist;
    const [name, setName] = useState(checklist?.name || "");
    const [checklistType, setChecklistType] = useState(checklist?.checklistType || "Standard");
    const [targetType, setTargetType] = useState(checklist?.targetType || "");
    const statuscode = STATUS_DRAFT;
    const [sections, setSections] = useState<ChecklistSection[]>(checklist?.sections || []);
    const [selectedSectionId, setSelectedSectionId] = useState<string | undefined>(
        () => findFirstLeafSection(checklist?.sections || [])?.id
    );
    const [currentVersion] = useState(checklist?.currentVersion || "1");

    useEffect(() => {
        const selectedSection = findSectionById(sections, selectedSectionId);
        const selectedLeaf = selectedSection && selectedSection.sections.length === 0 ? selectedSection : undefined;
        if (selectedLeaf) return;
        setSelectedSectionId(findFirstLeafSection(sections)?.id);
    }, [sections, selectedSectionId]);

    const selectedSection = useMemo(
        () => findSectionById(sections, selectedSectionId),
        [sections, selectedSectionId]
    );
    const selectedLeafSection = selectedSection && selectedSection.sections.length === 0
        ? selectedSection
        : findFirstLeafSection(selectedSection?.sections || sections);
    const definitionJson = useMemo(
        () => JSON.stringify({ name, checklistType, targetType, sections }, null, 2),
        [checklistType, name, sections, targetType]
    );
    const definitionHash = useMemo(() => hashText(definitionJson), [definitionJson]);

    const buildChecklistForSave = (): Checklist => ({
        id: checklist?.id,
        name,
        checklistType,
        targetType,
        statuscode,
        currentVersion: isNew ? "1" : (parseInt(currentVersion, 10) + 1).toString(),
        sections,
        definitionJson,
        definitionHash,
        raw: checklist?.raw,
    });

    const handleSave = (publishAction: "draft" | "submit") => {
        onSave(
            buildChecklistForSave(),
            isNew,
            publishAction
        );
    };

    const addSection = (parentSectionId?: string) => {
        const newSection: ChecklistSection = {
            id: makeId(),
            name: "",
            bulkServiceable: false,
            sections: [],
            items: [],
            parentId: parentSectionId || null,
        };
        setSections((prev) =>
            parentSectionId ? addChildSectionRecursive(prev, parentSectionId, newSection) : [...prev, newSection]
        );
        setSelectedSectionId(newSection.id);
    };

    const addItem = (sectionId: string) => {
        setSections((prev) =>
            addItemToSectionRecursive(prev, sectionId, {
                id: makeId(),
                name: "",
                description: "",
                quantity: 1,
            })
        );
        setSelectedSectionId(sectionId);
    };

    return (
        <div className={styles.editor}>
            <div className={styles.editorHeader}>
                <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                    <Button icon={<ArrowLeftRegular />} appearance="subtle" onClick={onBack}>
                        {t("back")}
                    </Button>
                    <Text as="h1" size={600} weight="semibold">
                        {isNew ? t("createChecklist") : t("editNextVersion")}
                    </Text>
                </div>
            </div>
            <Card>
                <CardHeader header={<Text weight="semibold">{t("details")}</Text>} />
                <div className={styles.detailsGrid}>
                    <Field label={t("checklistName")} required>
                        <Input value={name} onChange={(_, d) => setName(d.value)} />
                    </Field>
                    <Field label={t("checklistType")}>
                        <Dropdown
                            selectedOptions={[checklistType]}
                            value={checklistType}
                            onOptionSelect={(_, data) => {
                                setChecklistType(data.optionValue || "Standard");
                                if (data.optionValue !== "Standard") setTargetType("");
                            }}
                        >
                            {CHECKLIST_TYPES.map((type) => (
                                <Option key={type.key} value={type.key}>
                                    {type.text}
                                </Option>
                            ))}
                        </Dropdown>
                    </Field>
                    <Field label={t("checklistTargetType")} required={checklistType === "Standard"}>
                        <Dropdown
                            selectedOptions={targetType ? [targetType] : []}
                            value={targetType}
                            disabled={checklistType !== "Standard"}
                            onOptionSelect={(_, data) => setTargetType(data.optionValue || "")}
                        >
                            {TARGET_TYPES.map((target) => (
                                <Option key={target.key} value={target.key}>
                                    {target.text}
                                </Option>
                            ))}
                        </Dropdown>
                    </Field>
                    <Field label={t("status")}>
                        <Badge appearance="filled">{t("draft")}</Badge>
                    </Field>
                </div>
            </Card>
            <div className={styles.editorCanvas}>
                <div className={styles.sectionPane}>
                    <div className={styles.paneHeader}>
                        <Text weight="semibold">{t("sections")}</Text>
                        <Button appearance="subtle" icon={<AddRegular />} onClick={() => addSection()}>
                            {t("newTopLevelSection")}
                        </Button>
                    </div>
                    <div className={styles.sectionList}>
                        {sections.length === 0 ? (
                            <div className={styles.empty}>
                                <Text>{t("noSections")}</Text>
                            </div>
                        ) : (
                            sections.map((section) => (
                                <SectionEditor
                                    key={section.id}
                                    section={section}
                                    selectedSectionId={selectedLeafSection?.id}
                                    onSelectSection={(id) => {
                                        const sectionToSelect = findSectionById(sections, id);
                                        setSelectedSectionId(
                                            sectionToSelect?.sections.length
                                                ? findFirstLeafSection(sectionToSelect.sections)?.id
                                                : id
                                        );
                                    }}
                                    onUpdate={(id, updated) => setSections((prev) => updateSectionRecursive(prev, id, updated))}
                                    onRemove={(id) => setSections((prev) => removeSectionRecursive(prev, id))}
                                    onAddChild={addSection}
                                    onAddItem={addItem}
                                    onRemoveItem={(sectionId, itemId) =>
                                        setSections((prev) => removeItemFromSectionRecursive(prev, sectionId, itemId))
                                    }
                                    onUpdateItem={(sectionId, itemId, updated) =>
                                        setSections((prev) => updateItemInSectionRecursive(prev, sectionId, itemId, updated))
                                    }
                                    t={t}
                                />
                            ))
                        )}
                    </div>
                </div>
                <div className={styles.panelGap} aria-hidden="true" />
                <div className={styles.itemPane}>
                    <div className={styles.paneHeader}>
                        <Text weight="semibold">{t("definition")}</Text>
                        <Caption1>{selectedLeafSection?.name || t("selectSection")}</Caption1>
                    </div>
                    <div className={styles.itemList}>
                        {!selectedLeafSection ? (
                            <div className={styles.empty}>
                                <Text>{sections.length === 0 ? t("noItems") : t("selectSection")}</Text>
                            </div>
                        ) : (
                            <SectionItems
                                section={selectedLeafSection}
                                onAddItem={addItem}
                                onRemoveItem={(sectionId, itemId) =>
                                    setSections((prev) => removeItemFromSectionRecursive(prev, sectionId, itemId))
                                }
                                onUpdateItem={(sectionId, itemId, updated) =>
                                    setSections((prev) => updateItemInSectionRecursive(prev, sectionId, itemId, updated))
                                }
                                t={t}
                            />
                        )}
                    </div>
                </div>
            </div>
            <div className={styles.footer}>
                <Caption1>{t("versionNote")}</Caption1>
                <div style={{ display: "flex", gap: 8 }}>
                    <Button appearance="secondary" onClick={onBack}>
                        {t("cancel")}
                    </Button>
                    <Button
                        appearance="secondary"
                        icon={<SaveRegular />}
                        onClick={() => handleSave("draft")}
                        disabled={!name || (checklistType === "Standard" && !targetType)}
                    >
                        {t("saveDraft")}
                    </Button>
                    <Button
                        appearance="primary"
                        icon={<SaveRegular />}
                        onClick={() => handleSave("submit")}
                        disabled={!name || (checklistType === "Standard" && !targetType)}
                    >
                        {requireReviewForNewVersion ? t("submitForReview") : t("publishChecklist")}
                    </Button>
                </div>
            </div>
        </div>
    );
}

