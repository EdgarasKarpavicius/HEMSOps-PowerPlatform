function addChildSectionRecursive(sections: ChecklistSection[], parentId: string, newSection: ChecklistSection): ChecklistSection[] {
    return sections.map((section) =>
        section.id === parentId
            ? { ...section, sections: [...section.sections, newSection] }
            : { ...section, sections: addChildSectionRecursive(section.sections, parentId, newSection) }
    );
}

function removeSectionRecursive(sections: ChecklistSection[], sectionId: string): ChecklistSection[] {
    return sections
        .filter((section) => section.id !== sectionId)
        .map((section) => ({
            ...section,
            sections: removeSectionRecursive(section.sections, sectionId),
        }));
}

function updateSectionRecursive(
    sections: ChecklistSection[],
    sectionId: string,
    updated: Partial<ChecklistSection>
): ChecklistSection[] {
    return sections.map((section) =>
        section.id === sectionId
            ? { ...section, ...updated }
            : { ...section, sections: updateSectionRecursive(section.sections, sectionId, updated) }
    );
}

function addItemToSectionRecursive(
    sections: ChecklistSection[],
    sectionId: string,
    newItem: ChecklistItem
): ChecklistSection[] {
    return sections.map((section) =>
        section.id === sectionId
            ? { ...section, items: [...section.items, newItem] }
            : { ...section, sections: addItemToSectionRecursive(section.sections, sectionId, newItem) }
    );
}

function removeItemFromSectionRecursive(
    sections: ChecklistSection[],
    sectionId: string,
    itemId: string
): ChecklistSection[] {
    return sections.map((section) =>
        section.id === sectionId
            ? { ...section, items: section.items.filter((item) => item.id !== itemId) }
            : { ...section, sections: removeItemFromSectionRecursive(section.sections, sectionId, itemId) }
    );
}

function updateItemInSectionRecursive(
    sections: ChecklistSection[],
    sectionId: string,
    itemId: string,
    updated: Partial<ChecklistItem>
): ChecklistSection[] {
    return sections.map((section) =>
        section.id === sectionId
            ? { ...section, items: section.items.map((item) => (item.id === itemId ? { ...item, ...updated } : item)) }
            : { ...section, sections: updateItemInSectionRecursive(section.sections, sectionId, itemId, updated) }
    );
}

