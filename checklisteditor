function ChecklistDetails({
    version,
    statusOptions,
    onVersionSaved,
    t,
}: {
    version: ChecklistVersion;
    statusOptions: Record<number, StatusOption>;
    onVersionSaved: (version: ChecklistVersion) => void;
    t: (key: string) => string;
}) {
    const styles = useStyles();
    const checklist = version.checklist;
    const [activeTab, setActiveTab] = useState("general");
    const [isEditingName, setIsEditingName] = useState(false);
    const [isSaving, setIsSaving] = useState(false);
    const [saveError, setSaveError] = useState("");
    const [appliesToOptions, setAppliesToOptions] = useState<AppliesToOption[]>([]);
    const [proposedChecklistName, setProposedChecklistName] = useState(
        version.definition.checklistVersionDetails.proposedChecklistName || checklist.name
    );
    const [versionType, setVersionType] = useState(version.definition.checklistVersionDetails.versionType || VERSION_TYPE_MINOR);
    const [appliesTo, setAppliesTo] = useState<AppliesToSelection | null>(version.definition.checklistVersionDetails.appliesTo);
    const [options, setOptions] = useState(version.definition.checklistVersionDetails.options);

    useEffect(() => {
        let isMounted = true;
        loadAppliesToOptions(checklist.targetTypeValue).then((items) => {
            if (isMounted) setAppliesToOptions(items);
        });
        return () => {
            isMounted = false;
        };
    }, [checklist.targetTypeValue]);

    const currentDefinition = useMemo(
        () =>
            buildChecklistVersionDefinition({
                checklist,
                proposedChecklistName,
                versionType,
                appliesTo,
                options,
                sections: version.definition.checklistVersionContents.sections,
            }),
        [appliesTo, checklist, options, proposedChecklistName, version.definition.checklistVersionContents.sections, versionType]
    );
    const originalDefinitionText = useMemo(() => stableStringify(version.definition), [version.definition]);
    const currentDefinitionText = useMemo(() => stableStringify(currentDefinition), [currentDefinition]);
    const hasDefinitionChanges = currentDefinitionText !== originalDefinitionText;
    const appliesToTarget = APPLIES_TO_TARGETS[checklist.targetTypeValue];

    const updateOption = (key: string, value: boolean | number | string) => {
        setOptions((current) =>
            current.map((option) => (option.key === key ? { ...option, value } : option))
        );
    };
    const handleSave = async () => {
        setSaveError("");
        setIsSaving(true);
        try {
            const saved = await saveChecklistVersionDefinition(version, currentDefinition);
            onVersionSaved(saved);
        } catch (error) {
            setSaveError(error instanceof Error ? error.message : "Unable to save checklist version.");
        } finally {
            setIsSaving(false);
        }
    };
    const sectionCount = version.definition.checklistVersionContents.sections.length;

    return (
        <div className={styles.detailsPage}>
            <div className={styles.editorHeader}>
                <div className={styles.titleStack}>
                    <Text className={styles.eyebrow}>{`${checklist.checklistType} Checklist`}</Text>
                    <div className={styles.editableTitleRow}>
                        {isEditingName ? (
                            <Input
                                className={styles.titleInput}
                                value={proposedChecklistName}
                                onChange={(_, data) => setProposedChecklistName(data.value)}
                                onBlur={() => setIsEditingName(false)}
                            />
                        ) : (
                            <>
                                <Text as="h1" className={styles.pageTitle}>
                                    {proposedChecklistName || checklist.name}
                                </Text>
                                <Button
                                    aria-label="Edit checklist name"
                                    appearance="subtle"
                                    icon={<EditRegular />}
                                    onClick={() => setIsEditingName(true)}
                                />
                            </>
                        )}
                    </div>
                    <Caption1 block className={styles.pageSubtitle}>
                        {`${t("version")}: ${version.versionNumber || "-"}`}
                    </Caption1>
                    {checklist.targetType && (
                        <Caption1 block className={styles.pageSubtitle}>
                            {`Target Type: ${checklist.targetType}`}
                        </Caption1>
                    )}
                </div>
                <div className={styles.headerAction}>
                    <Button
                        appearance="primary"
                        icon={<SaveRegular />}
                        disabled={!hasDefinitionChanges || isSaving}
                        onClick={handleSave}
                    >
                        {isSaving ? "Saving" : "Save"}
                    </Button>
                    <StatusPill
                        statuscode={version.statuscode}
                        fallbackLabel={version.statusLabel}
                        statusOptions={statusOptions}
                        className={`${styles.statusPill} ${styles.headerStatusPill}`}
                    />
                </div>
            </div>
            {saveError && (
                <MessageBar intent="error">
                    <MessageBarBody>{saveError}</MessageBarBody>
                </MessageBar>
            )}
            <div className={styles.workbenchSurface}>
                <div className={styles.workbenchTabs}>
                    <TabList
                        selectedValue={activeTab}
                        onTabSelect={(_, data) => setActiveTab(String(data.value))}
                    >
                        <Tab value="general">General</Tab>
                        <Tab value="contents">Contents</Tab>
                    </TabList>
                </div>
                {activeTab === "general" ? (
                    <div className={styles.tabPanel}>
                        <div className={styles.generalGrid}>
                            <div className={styles.formStack}>
                                <Field label="Version type">
                                    <Dropdown
                                        selectedOptions={[String(versionType)]}
                                        value={VERSION_TYPES.find((item) => item.key === versionType)?.text || ""}
                                        onOptionSelect={(_, data) => setVersionType(Number(data.optionValue) || VERSION_TYPE_MINOR)}
                                    >
                                        {VERSION_TYPES.map((item) => (
                                            <Option key={item.key} value={String(item.key)}>
                                                {item.text}
                                            </Option>
                                        ))}
                                    </Dropdown>
                                </Field>
                                <Field label="Applies To">
                                    <Dropdown
                                        placeholder={appliesToTarget ? `Select ${appliesToTarget.label.toLowerCase()}` : "No target type"}
                                        selectedOptions={appliesTo?.id ? [appliesTo.id] : []}
                                        value={appliesTo ? getAppliesToOptionText(appliesTo) : ""}
                                        disabled={!appliesToTarget}
                                        onOptionSelect={(_, data) => {
                                            const selected = appliesToOptions.find((item) => item.id === data.optionValue) || null;
                                            setAppliesTo(selected);
                                        }}
                                    >
                                        {appliesToOptions.map((item) => (
                                            <Option key={item.id} value={item.id}>
                                                <span>
                                                    {item.category && (
                                                        <span className={styles.optionGroupText}>{`${item.category} / `}</span>
                                                    )}
                                                    {item.name}
                                                </span>
                                            </Option>
                                        ))}
                                    </Dropdown>
                                </Field>
                            </div>
                            <div className={styles.formStack}>
                                <Text weight="semibold">Options</Text>
                                <div className={styles.optionsList}>
                                    {options.map((option) => {
                                        const definition = CHECKLIST_OPTION_DEFINITIONS.find(
                                            (candidate) => candidate.key === option.key
                                        );
                                        if (!definition) return null;

                                        return (
                                            <div className={styles.optionRow} key={option.key}>
                                                <div className={styles.optionLabel}>
                                                    <Text weight="semibold">{definition.label}</Text>
                                                </div>
                                                {definition.type === "number" ? (
                                                    <Input
                                                        type="number"
                                                        min={1}
                                                        value={String(option.value || 1)}
                                                        onChange={(_, data) =>
                                                            updateOption(option.key, Math.max(1, Number(data.value) || 1))
                                                        }
                                                        style={{ width: 96 }}
                                                    />
                                                ) : (
                                                    <Checkbox
                                                        checked={Boolean(option.value)}
                                                        onChange={(_, data) => updateOption(option.key, Boolean(data.checked))}
                                                    />
                                                )}
                                            </div>
                                        );
                                    })}
                                </div>
                            </div>
                        </div>
                    </div>
                ) : (
                    <div className={styles.tabPanel}>
                        <div className={styles.contentsPlaceholder}>
                            <Text weight="semibold">{`${sectionCount} section${sectionCount === 1 ? "" : "s"}`}</Text>
                        </div>
                    </div>
                )}
            </div>
        </div>
    );
}

function ChecklistEditor({
    checklist,
    onBack,
    onSave,
    requireReviewForNewVersion,
    statusOptions,
    t,
}: {
    checklist: Checklist | null;
    onBack: () => void;
    onSave: (c: Checklist, isNew: boolean, publishAction: "draft" | "submit") => void;
    requireReviewForNewVersion: boolean;
    statusOptions: Record<number, StatusOption>;
    t: (key: string) => string;
}) {
    const styles = useStyles();
    const isNew = !checklist;
    const [name, setName] = useState(checklist?.name || "");
    const [checklistType, setChecklistType] = useState(checklist?.checklistType || "Standard");
    const [targetType, setTargetType] = useState(checklist?.targetType || "");
    const statuscode = STATUS_DRAFT;
    const [sections, setSections] = useState<ChecklistSection[]>(checklist?.sections || []);
    const [selectedSectionId, setSelectedSectionId] = useState<string | undefined>(
        () => findFirstLeafSection(checklist?.sections || [])?.id
    );
    const [currentVersion] = useState(checklist?.currentVersion || "1");

    useEffect(() => {
        const selectedSection = findSectionById(sections, selectedSectionId);
        const selectedLeaf = selectedSection && selectedSection.sections.length === 0 ? selectedSection : undefined;
        if (selectedLeaf) return;
        setSelectedSectionId(findFirstLeafSection(sections)?.id);
    }, [sections, selectedSectionId]);

    const selectedSection = useMemo(
        () => findSectionById(sections, selectedSectionId),
        [sections, selectedSectionId]
    );
    const selectedLeafSection = selectedSection && selectedSection.sections.length === 0
        ? selectedSection
        : findFirstLeafSection(selectedSection?.sections || sections);
    const definitionJson = useMemo(
        () => JSON.stringify({ name, checklistType, targetType, sections }, null, 2),
        [checklistType, name, sections, targetType]
    );
    const definitionHash = useMemo(() => hashText(definitionJson), [definitionJson]);

    const buildChecklistForSave = (): Checklist => ({
        id: checklist?.id,
        name,
        checklistType,
        targetType,
        statuscode,
        currentVersion: isNew ? "1" : (parseInt(currentVersion, 10) + 1).toString(),
        sections,
        definitionJson,
        definitionHash,
        raw: checklist?.raw,
    });

    const handleSave = (publishAction: "draft" | "submit") => {
        onSave(
            buildChecklistForSave(),
            isNew,
            publishAction
        );
    };

    const addSection = (parentSectionId?: string) => {
        const newSection: ChecklistSection = {
            id: makeId(),
            name: "",
            bulkServiceable: false,
            sections: [],
            items: [],
            parentId: parentSectionId || null,
        };
        setSections((prev) =>
            parentSectionId ? addChildSectionRecursive(prev, parentSectionId, newSection) : [...prev, newSection]
        );
        setSelectedSectionId(newSection.id);
    };

    const addItem = (sectionId: string) => {
        setSections((prev) =>
            addItemToSectionRecursive(prev, sectionId, {
                id: makeId(),
                name: "",
                description: "",
                quantity: 1,
            })
        );
        setSelectedSectionId(sectionId);
    };

    return (
        <div className={styles.editor}>
            <div className={styles.editorHeader}>
                <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                    <Button icon={<ArrowLeftRegular />} appearance="subtle" onClick={onBack}>
                        {t("back")}
                    </Button>
                    <Text as="h1" size={600} weight="semibold">
                        {isNew ? t("createChecklist") : t("editNextVersion")}
                    </Text>
                </div>
            </div>
            <Card>
                <CardHeader header={<Text weight="semibold">{t("details")}</Text>} />
                <div className={styles.detailsGrid}>
                    <Field label={t("checklistName")} required>
                        <Input value={name} onChange={(_, d) => setName(d.value)} />
                    </Field>
                    <Field label={t("checklistType")}>
                        <Dropdown
                            selectedOptions={[checklistType]}
                            value={checklistType}
                            onOptionSelect={(_, data) => {
                                setChecklistType(data.optionValue || "Standard");
                                if (data.optionValue !== "Standard") setTargetType("");
                            }}
                        >
                            {CHECKLIST_TYPES.map((type) => (
                                <Option key={type.key} value={type.key}>
                                    {type.text}
                                </Option>
                            ))}
                        </Dropdown>
                    </Field>
                    <Field label={t("checklistTargetType")} required={checklistType === "Standard"}>
                        <Dropdown
                            selectedOptions={targetType ? [targetType] : []}
                            value={targetType}
                            disabled={checklistType !== "Standard"}
                            onOptionSelect={(_, data) => setTargetType(data.optionValue || "")}
                        >
                            {TARGET_TYPES.map((target) => (
                                <Option key={target.key} value={target.key}>
                                    {target.text}
                                </Option>
                            ))}
                        </Dropdown>
                    </Field>
                    <Field label={t("status")}>
                        <StatusPill statuscode={STATUS_DRAFT} statusOptions={statusOptions} className={styles.statusPill} />
                    </Field>
                </div>
            </Card>
            <div className={styles.editorCanvas}>
                <div className={styles.sectionPane}>
                    <div className={styles.paneHeader}>
                        <Text weight="semibold">{t("sections")}</Text>
                        <Button appearance="subtle" icon={<AddRegular />} onClick={() => addSection()}>
                            {t("newTopLevelSection")}
                        </Button>
                    </div>
                    <div className={styles.sectionList}>
                        {sections.length === 0 ? (
                            <div className={styles.empty}>
                                <Text>{t("noSections")}</Text>
                            </div>
                        ) : (
                            sections.map((section) => (
                                <SectionEditor
                                    key={section.id}
                                    section={section}
                                    selectedSectionId={selectedLeafSection?.id}
                                    onSelectSection={(id) => {
                                        const sectionToSelect = findSectionById(sections, id);
                                        setSelectedSectionId(
                                            sectionToSelect?.sections.length
                                                ? findFirstLeafSection(sectionToSelect.sections)?.id
                                                : id
                                        );
                                    }}
                                    onUpdate={(id, updated) => setSections((prev) => updateSectionRecursive(prev, id, updated))}
                                    onRemove={(id) => setSections((prev) => removeSectionRecursive(prev, id))}
                                    onAddChild={addSection}
                                    onAddItem={addItem}
                                    onRemoveItem={(sectionId, itemId) =>
                                        setSections((prev) => removeItemFromSectionRecursive(prev, sectionId, itemId))
                                    }
                                    onUpdateItem={(sectionId, itemId, updated) =>
                                        setSections((prev) => updateItemInSectionRecursive(prev, sectionId, itemId, updated))
                                    }
                                    t={t}
                                />
                            ))
                        )}
                    </div>
                </div>
                <div className={styles.panelGap} aria-hidden="true" />
                <div className={styles.itemPane}>
                    <div className={styles.paneHeader}>
                        <Text weight="semibold">{t("definition")}</Text>
                        <Caption1>{selectedLeafSection?.name || t("selectSection")}</Caption1>
                    </div>
                    <div className={styles.itemList}>
                        {!selectedLeafSection ? (
                            <div className={styles.empty}>
                                <Text>{sections.length === 0 ? t("noItems") : t("selectSection")}</Text>
                            </div>
                        ) : (
                            <SectionItems
                                section={selectedLeafSection}
                                onAddItem={addItem}
                                onRemoveItem={(sectionId, itemId) =>
                                    setSections((prev) => removeItemFromSectionRecursive(prev, sectionId, itemId))
                                }
                                onUpdateItem={(sectionId, itemId, updated) =>
                                    setSections((prev) => updateItemInSectionRecursive(prev, sectionId, itemId, updated))
                                }
                                t={t}
                            />
                        )}
                    </div>
                </div>
            </div>
            <div className={styles.footer}>
                <Caption1>{t("versionNote")}</Caption1>
                <div style={{ display: "flex", gap: 8 }}>
                    <Button appearance="secondary" onClick={onBack}>
                        {t("cancel")}
                    </Button>
                    <Button
                        appearance="secondary"
                        icon={<SaveRegular />}
                        onClick={() => handleSave("draft")}
                        disabled={!name || (checklistType === "Standard" && !targetType)}
                    >
                        {t("saveDraft")}
                    </Button>
                    <Button
                        appearance="primary"
                        icon={<SaveRegular />}
                        onClick={() => handleSave("submit")}
                        disabled={!name || (checklistType === "Standard" && !targetType)}
                    >
                        {requireReviewForNewVersion ? t("submitForReview") : t("publishChecklist")}
                    </Button>
                </div>
            </div>
        </div>
    );
}

