                if (hasDataverse()) {
                    const versionId = normalizeLookupValue(
                        pageInput.data?.checklistVersionId ||
                            pageInput.data?.int_checklistversionid ||
                            pageInput.recordId ||
                            TEMP_DEV_CHECKLIST_VERSION_ID
                    );
                    const [version, statusMetadata] = await Promise.all([
                        loadChecklistVersionFromDataverse(versionId),
                        loadStatusOptions(VERSION_TABLE_NAME),
                    ]);
                    if (isMounted) {
                        setSelectedVersion(version);
                        setStatusOptions(statusMetadata);
                    }
                } else if (isMounted) {
                    setMessage(t("loadFallback"));
                    setSelectedVersion(null);
                }
            } catch (error) {
                if (isMounted) {
                    setMessage(error instanceof Error ? error.message : t("loadFallback"));
                    setSelectedVersion(null);
                }
            } finally {
                if (isMounted) setIsLoading(false);
            }
        }
        load();
        return () => {
            isMounted = false;
        };
    }, [pageInput, t]);

    return (
        <div dir={isRTL ? "rtl" : "ltr"} className={styles.page}>
            <div className={styles.shell}>
                {message && (
                    <MessageBar intent="warning">
                        <MessageBarBody>{message}</MessageBarBody>
                    </MessageBar>
                )}
                {isLoading ? (
                    <FocusedChecklistLoading t={t} />
                ) : selectedVersion ? (
                    <ChecklistDetails
                        version={selectedVersion}
                        statusOptions={statusOptions}
                        onVersionSaved={setSelectedVersion}
                        t={t}
                    />
                ) : (
                    <FocusedChecklistEmpty t={t} />
                )}
            </div>
        </div>
    );
};

function FocusedChecklistLoading({ t }: { t: (key: string) => string }) {
    const styles = useStyles();
    return (
        <div className={styles.detailsPage}>
            <div className={styles.header}>
                <div className={styles.titleStack}>
                    <Text className={styles.eyebrow}>{t("loadingChecklist")}</Text>
                    <Text as="h1" className={styles.pageTitle}>
                        {t("loadingChecklist")}
                    </Text>
                </div>
            </div>
            <div className={styles.versionsSurface}>
                <div className={styles.empty}>
                    <Spinner label={t("loadingChecklist")} />
                </div>
            </div>
        </div>
    );
}

function FocusedChecklistEmpty({
    t,
}: {
    t: (key: string) => string;
}) {
    const styles = useStyles();
    return (
        <div className={styles.detailsPage}>
            <div className={styles.header}>
                <div className={styles.titleStack}>
                    <Text className={styles.eyebrow}>{t("focusedContext")}</Text>
                    <Text as="h1" className={styles.pageTitle}>
                        {t("noFocusedChecklist")}
                    </Text>
                </div>
            </div>
            <div className={styles.versionsSurface}>
                <div className={styles.emptyVersionPlaceholder}>
                    <div>
                        <Text block weight="semibold">{t("noFocusedChecklist")}</Text>
                    </div>
                </div>
            </div>
        </div>
    );
}

function ChecklistDetails({
    version,
    statusOptions,
    onVersionSaved,
    t,
}: {
    version: ChecklistVersion;
    statusOptions: Record<number, StatusOption>;
    onVersionSaved: (version: ChecklistVersion) => void;
    t: (key: string) => string;
}) {
    const styles = useStyles();
    const checklist = version.checklist;
    const [activeTab, setActiveTab] = useState("general");
    const [isEditingName, setIsEditingName] = useState(false);
    const [isSaving, setIsSaving] = useState(false);
    const [saveError, setSaveError] = useState("");
    const [appliesToOptions, setAppliesToOptions] = useState<AppliesToOption[]>([]);
    const [proposedChecklistName, setProposedChecklistName] = useState(
        version.definition.checklistVersionDetails.proposedChecklistName || checklist.name
    );
    const [versionType, setVersionType] = useState(version.versionType || version.definition.checklistVersionDetails.versionType || VERSION_TYPE_MINOR);
    const [versionNumber, setVersionNumber] = useState(
        version.versionNumber || version.definition.checklistVersionDetails.versionNumber || ""
    );
    const [description, setDescription] = useState(
        version.description || version.definition.checklistVersionDetails.description || ""
    );
    const [appliesTo, setAppliesTo] = useState<AppliesToSelection | null>(version.definition.checklistVersionDetails.appliesTo);
    const [options, setOptions] = useState(version.definition.checklistVersionDetails.options);
    const [sections, setSections] = useState(version.definition.checklistVersionContents.sections);
    const [selectedSectionId, setSelectedSectionId] = useState(
        flattenSections(version.definition.checklistVersionContents.sections)[0]?.section.id || ""
    );
    const [draftSection, setDraftSection] = useState<DraftSection | null>(null);
    const [draftItem, setDraftItem] = useState<DraftItem | null>(null);
    const [draggedItem, setDraggedItem] = useState<DraggedItem>(null);
    const [dragOverTarget, setDragOverTarget] = useState<DragOverTarget>(null);
    const [pendingSectionPromotion, setPendingSectionPromotion] = useState<PendingSectionPromotion>(null);
    const [pendingDelete, setPendingDelete] = useState<PendingDelete>(null);
    const [collapsedSectionIds, setCollapsedSectionIds] = useState<Set<string>>(() => new Set());

    useEffect(() => {
        let isMounted = true;
        loadAppliesToOptions(checklist.targetTypeValue).then((items) => {
            if (isMounted) setAppliesToOptions(items);
        });
        return () => {
            isMounted = false;
        };
    }, [checklist.targetTypeValue]);

    const currentDefinition = useMemo(
        () =>
            buildChecklistVersionDefinition({
                checklist,
                proposedChecklistName,
                versionType,
                versionNumber,
                description,
                appliesTo,
                options,
                sections,
            }),
        [appliesTo, checklist, description, options, proposedChecklistName, sections, versionNumber, versionType]
    );
    const originalDefinitionText = useMemo(() => stableStringify(version.definition), [version.definition]);
    const currentDefinitionText = useMemo(() => stableStringify(currentDefinition), [currentDefinition]);
    const hasDefinitionChanges = currentDefinitionText !== originalDefinitionText;
    const appliesToTarget = APPLIES_TO_TARGETS[checklist.targetTypeValue];

    const updateOption = (key: string, value: boolean | number | string) => {
        setOptions((current) =>
            current.map((option) => (option.key === key ? { ...option, value } : option))
        );
    };
    const flattenedSections = useMemo(() => flattenSections(sections), [sections]);
    const selectedSection = useMemo(
        () => findSectionById(sections, selectedSectionId),
        [sections, selectedSectionId]
    );
    const selectedSectionPath = useMemo(
        () => findSectionPathById(sections, selectedSectionId),
        [sections, selectedSectionId]
    );
    const selectedSectionDepth = flattenedSections.find(({ section }) => section.id === selectedSectionId)?.depth ?? 0;
    const canAddChildSection = Boolean(selectedSection && selectedSectionDepth === 0 && selectedSection.items.length === 0);
    const selectedSectionHasChildren = Boolean(selectedSection && selectedSection.sections.length > 0);
    const draggedSectionPath = useMemo(
        () => draggedItem?.type === "section" ? findSectionPathById(sections, draggedItem.id) : [],
        [draggedItem, sections]
    );
    const isDraggingChildSection = draggedSectionPath.length > 1;
    const startNewSection = (parentId: string | null) => {
        setDraftSection({ parentId, name: "" });
        setDraftItem(null);
        if (parentId) {
            setCollapsedSectionIds((current) => {
                const next = new Set(current);
                next.delete(parentId);
                return next;
            });
        }
    };
    const confirmDraftSection = () => {
        if (!draftSection?.name.trim()) return;
        const newSection = createEmptySection(draftSection.name, draftSection.parentId);
        setSections((current) => appendSection(current, draftSection.parentId, newSection));
        setSelectedSectionId(newSection.id);
        setDraftSection(null);
    };
    const toggleCollapsedSection = (sectionId: string) => {
        setCollapsedSectionIds((current) => {
            const next = new Set(current);
            if (next.has(sectionId)) {
                next.delete(sectionId);
            } else {
                next.add(sectionId);
            }
            return next;
        });
    };
    const startNewItem = (sectionId: string) => {
        setDraftItem({ sectionId, name: "", description: "", quantity: "" });
        setDraftSection(null);
    };
    const handleChecklistShortcutKeyDown = (event: React.KeyboardEvent) => {
        if (event.key !== " " || activeTab !== "contents" || !selectedSection || draftSection || draftItem) return;
        const target = event.target as HTMLElement | null;
        const tagName = target?.tagName.toLowerCase();
        if (
            tagName === "input" ||
            tagName === "textarea" ||
            tagName === "select" ||
            tagName === "button" ||
            target?.isContentEditable
        ) {
            return;
        }

        if (selectedSectionHasChildren && canAddChildSection) {
            event.preventDefault();
            startNewSection(selectedSection.id);
            return;
        }
        if (!selectedSectionHasChildren) {
            event.preventDefault();
            startNewItem(selectedSection.id);
        }
    };
    const startEditItem = (sectionId: string, item: ChecklistItem) => {
        setDraftItem({
            sectionId,
            itemId: item.id,
            name: item.name,
            description: item.description,
            quantity: item.quantity === null || item.quantity === undefined ? "" : String(item.quantity),
        });
        setDraftSection(null);
    };
    const confirmDraftItem = () => {
        if (!draftItem?.name.trim()) return;
        const item = createChecklistItemFromDraft(draftItem);
        setSections((current) =>
            draftItem.itemId
                ? updateItemInSection(current, draftItem.sectionId, item)
                : appendItemToSection(current, draftItem.sectionId, item)
        );
        setDraftItem(null);
    };
    const handleItemEditKeyDown = (event: React.KeyboardEvent, allowShiftEnter = false) => {
        if (event.key === "Enter" && (!allowShiftEnter || !event.shiftKey)) {
            event.preventDefault();
            confirmDraftItem();
        }
        if (event.key === "Escape") setDraftItem(null);
    };
    const handleSectionDrop = (targetSection: ChecklistSection) => {
        if (draggedItem?.type !== "section") return;
        const draggedSection = flattenedSections.find(({ section }) => section.id === draggedItem.id)?.section;
        if (!draggedSection || (draggedSection.parentId || null) !== (targetSection.parentId || null)) return;
        setSections((current) =>
            reorderSiblingSections(current, targetSection.parentId || null, draggedItem.id, targetSection.id)
        );
        setDraggedItem(null);
        setDragOverTarget(null);
    };
    const handleItemDrop = (targetItem: ChecklistItem) => {
        if (draggedItem?.type !== "item" || draggedItem.sectionId !== selectedSectionId) return;
        setSections((current) =>
            reorderSectionItems(current, selectedSectionId, draggedItem.id, targetItem.id)
        );
        setDraggedItem(null);
        setDragOverTarget(null);
    };
    const canDropSectionOnTarget = (targetSection: ChecklistSection) => {
        if (draggedItem?.type !== "section" || draggedItem.id === targetSection.id) return false;
        const draggedSection = flattenedSections.find(({ section }) => section.id === draggedItem.id)?.section;
        return Boolean(draggedSection && (draggedSection.parentId || null) === (targetSection.parentId || null));
    };
    const canDropItemOnTarget = (targetItem: ChecklistItem) =>
        Boolean(draggedItem?.type === "item" && draggedItem.sectionId === selectedSectionId && draggedItem.id !== targetItem.id);
    const handlePromoteSectionDrop = () => {
        if (!isDraggingChildSection || draggedItem?.type !== "section") return;
        const section = draggedSectionPath[draggedSectionPath.length - 1];
        const parent = draggedSectionPath[draggedSectionPath.length - 2];
        setPendingSectionPromotion({
            sectionId: section.id,
            sectionName: section.name || "Untitled section",
            parentName: parent?.name || "its parent section",
        });
        setDraggedItem(null);
        setDragOverTarget(null);
    };
    const confirmSectionPromotion = () => {
        if (!pendingSectionPromotion) return;
        setSections((current) => promoteSectionToTopLevel(current, pendingSectionPromotion.sectionId));
        setSelectedSectionId(pendingSectionPromotion.sectionId);
        setPendingSectionPromotion(null);
    };
    const requestDeleteSection = (section: ChecklistSection) => {
        const totals = countSectionContents(section);
        const requiresConfirmation = totals.sections > 0 || totals.items > 0;
        if (!requiresConfirmation) {
            setSections((current) => removeSectionById(current, section.id).sections);
            if (selectedSectionPath.some((candidate) => candidate.id === section.id)) setSelectedSectionId("");
            return;
        }
        setPendingDelete({
            type: "section",
            id: section.id,
            name: section.name || "Untitled section",
        });
    };
    const requestDeleteItem = (sectionId: string, item: ChecklistItem) => {
        setPendingDelete({
            type: "item",
            sectionId,
            id: item.id,
            name: item.name || "Untitled item",
        });
    };
    const confirmDelete = () => {
        if (!pendingDelete) return;
        if (pendingDelete.type === "section") {
            setSections((current) => removeSectionById(current, pendingDelete.id).sections);
            if (selectedSectionPath.some((candidate) => candidate.id === pendingDelete.id)) setSelectedSectionId("");
        } else {
            setSections((current) => removeItemFromSection(current, pendingDelete.sectionId, pendingDelete.id));
            if (draftItem?.itemId === pendingDelete.id) setDraftItem(null);
        }
        setPendingDelete(null);
    };
    const renderDraftSectionRow = (depth = 0) => (
        <div
            className={styles.draftSectionRow}
            style={{ marginLeft: depth * 18 }}
        >
            <Input
                autoFocus
                placeholder="Section name"
                value={draftSection?.name || ""}
                onChange={(_, data) =>
                    setDraftSection((current) => current ? { ...current, name: data.value } : current)
                }
                onKeyDown={(event) => {
                    if (event.key === "Enter") confirmDraftSection();
                    if (event.key === "Escape") setDraftSection(null);
                }}
            />
            <Button
                aria-label="Confirm section"
                appearance="primary"
                icon={<CheckmarkRegular />}
                disabled={!draftSection?.name.trim()}
                onClick={confirmDraftSection}
            />
        </div>
    );
    const renderDraftItemRow = () => (
        <div className={styles.itemEditCard}>
            <Field label="Name" className={styles.itemNameField}>
                <Input
                    autoFocus
                    placeholder="Enter item name"
                    value={draftItem?.name || ""}
                    onChange={(_, data) =>
                        setDraftItem((current) => current ? { ...current, name: data.value } : current)
                    }
                    onKeyDown={(event) => handleItemEditKeyDown(event)}
                />
            </Field>
            <Field label="Quantity" className={styles.itemQuantityField}>
                <Input
                    type="number"
                    min={0}
                    placeholder="None"
                    value={draftItem?.quantity || ""}
                    onChange={(_, data) =>
                        setDraftItem((current) => current ? { ...current, quantity: data.value } : current)
                    }
                    onKeyDown={(event) => handleItemEditKeyDown(event)}
                />
            </Field>
            <Field label="Description" className={styles.itemDescriptionField}>
                <Textarea
                    resize="vertical"
                    rows={3}
                    placeholder="Add guidance, acceptance criteria, or notes for this item"
                    value={draftItem?.description || ""}
                    onChange={(_, data) =>
                        setDraftItem((current) => current ? { ...current, description: data.value } : current)
                    }
                    onKeyDown={(event) => handleItemEditKeyDown(event, true)}
                />
            </Field>
            <Button
                aria-label="Confirm checklist item"
                appearance="primary"
                className={styles.itemConfirmButton}
                icon={<CheckmarkRegular />}
                disabled={!draftItem?.name.trim()}
                onClick={confirmDraftItem}
            />
        </div>
    );
    const renderSectionRow = (section: ChecklistSection, depth = 0): React.ReactNode => {
        const hasChildren = section.sections.length > 0;
        const isCollapsed = collapsedSectionIds.has(section.id);
        const isDropTarget = dragOverTarget?.type === "section" && dragOverTarget.id === section.id;

        return (
            <React.Fragment key={section.id}>
                <div
                    className={[
                        styles.sectionRow,
                        depth === 0 ? styles.parentSectionRow : styles.childSectionRow,
                        selectedSectionId === section.id ? styles.selectedSectionRow : "",
                        draggedItem?.type === "section" && draggedItem.id === section.id ? styles.draggingRow : "",
                        isDropTarget ? styles.dropBeforeRow : "",
                    ].filter(Boolean).join(" ")}
                    draggable
                    tabIndex={0}
                    onClick={() => {
                        setSelectedSectionId(section.id);
                        setDraftItem(null);
                    }}
                    onDragStart={(event) => {
                        event.dataTransfer.effectAllowed = "move";
                        event.dataTransfer.setData("text/plain", section.id);
                        setDraggedItem({ type: "section", id: section.id });
                    }}
                    onDragOver={(event) => {
                        if (!canDropSectionOnTarget(section)) {
                            if (dragOverTarget?.type === "section" && dragOverTarget.id === section.id) setDragOverTarget(null);
                            return;
                        }
                        event.preventDefault();
                        setDragOverTarget({ type: "section", id: section.id });
                    }}
                    onDrop={(event) => {
                        event.preventDefault();
                        handleSectionDrop(section);
                    }}
                    onDragLeave={() => {
                        if (dragOverTarget?.type === "section" && dragOverTarget.id === section.id) setDragOverTarget(null);
                    }}
                    onDragEnd={() => {
                        setDraggedItem(null);
                        setDragOverTarget(null);
                    }}
                >
                    <div className={styles.sectionMain}>
                        {hasChildren ? (
                            <Button
                                aria-label={isCollapsed ? "Expand section" : "Collapse section"}
                                appearance="subtle"
                                className={styles.sectionChevron}
                                icon={isCollapsed ? <ChevronRightRegular /> : <ChevronDownRegular />}
                                onClick={(event) => {
                                    event.stopPropagation();
                                    toggleCollapsedSection(section.id);
                                }}
                            />
                        ) : (
                            <span className={styles.sectionChevron} />
                        )}
                        <Text className={styles.sectionRowText} weight={depth === 0 || selectedSectionId === section.id ? "semibold" : "regular"}>
                            {section.name || "Untitled section"}
                        </Text>
                    </div>
                    <Caption1 className={styles.mutedText}>
                        {hasChildren ? `${section.sections.length} child` : `${section.items.length} item`}
                    </Caption1>
                    <div className={styles.rowActions}>
                        <Button
                            aria-label="Delete section"
                            appearance="subtle"
                            icon={<DeleteRegular />}
                            onClick={(event) => {
                                event.stopPropagation();
                                requestDeleteSection(section);
                            }}
                        />
                    </div>
                </div>
                {hasChildren && !isCollapsed && (
                    <div className={styles.sectionChildren}>
                        {section.sections.map((childSection) => renderSectionRow(childSection, depth + 1))}
                    </div>
                )}
                {draftSection?.parentId === section.id && renderDraftSectionRow(depth + 1)}
            </React.Fragment>
        );
    };
    const handleSave = async () => {
        setSaveError("");
        setIsSaving(true);
        try {
            const saved = await saveChecklistVersionDefinition(version, currentDefinition);
            onVersionSaved(saved);
        } catch (error) {
            setSaveError(error instanceof Error ? error.message : "Unable to save checklist version.");
        } finally {
            setIsSaving(false);
        }
    };
    const sectionCount = flattenedSections.length;

    return (
        <div className={styles.detailsPage} tabIndex={0} onKeyDown={handleChecklistShortcutKeyDown}>
            <div className={styles.editorHeader}>
                <div className={styles.titleStack}>
                    <Text className={styles.eyebrow}>{checklist.checklistType ? `${checklist.checklistType} Checklist` : "Checklist"}</Text>
                    <div className={styles.editableTitleRow}>
                        {isEditingName ? (
                            <Input
                                className={styles.titleInput}
                                value={proposedChecklistName}
                                onChange={(_, data) => setProposedChecklistName(data.value)}
                                onBlur={() => setIsEditingName(false)}
                            />
                        ) : (
                            <>
                                <Text as="h1" className={styles.pageTitle}>
                                    {proposedChecklistName || checklist.name}
                                </Text>
                                <Button
                                    aria-label="Edit checklist name"
                                    appearance="subtle"
                                    icon={<EditRegular />}
                                    onClick={() => setIsEditingName(true)}
                                />
                            </>
                        )}
                    </div>
                    {version.statecode === 1 && (
                        <Caption1 block className={styles.pageSubtitle}>
                            {`${t("version")}: ${formatVersionNumber(versionNumber) || "-"}`}
                        </Caption1>
                    )}
                    {checklist.targetType && (
                        <Caption1 block className={styles.pageSubtitle}>
                            {`Target Type: ${checklist.targetType}`}
                        </Caption1>
                    )}
                </div>
                <div className={styles.headerAction}>
                    <StatusPill
                        statuscode={version.statuscode}
                        fallbackLabel={version.statusLabel}
                        statusOptions={statusOptions}
                        className={`${styles.statusPill} ${styles.headerStatusPill}`}
                    />
                </div>
            </div>
            {saveError && (
                <MessageBar intent="error">
                    <MessageBarBody>{saveError}</MessageBarBody>
                </MessageBar>
            )}
            <div className={styles.tabSurface}>
                <div className={styles.tabHeader}>
                    <TabList
                        selectedValue={activeTab}
                        onTabSelect={(_, data) => setActiveTab(String(data.value))}
                    >
                        <Tab value="general">General</Tab>
                        <Tab value="contents">Contents</Tab>
                        <Tab value="options">Options</Tab>
                    </TabList>
                    {hasDefinitionChanges && (
                        <Button
                            appearance="primary"
                            icon={<SaveRegular />}
                            disabled={isSaving}
                            onClick={handleSave}
                        >
                            {isSaving ? "Saving" : "Save"}
                        </Button>
                    )}
                </div>
                {activeTab === "general" ? (
                    <div className={styles.tabPanel}>
                        <div className={styles.formStack}>
                            <section className={styles.generalSection}>
                                <Text className={styles.generalSectionTitle}>Version Details</Text>
                                <Field label="Version type">
                                    <Dropdown
                                        className={styles.controlFullWidth}
                                        selectedOptions={[String(versionType)]}
                                        value={VERSION_TYPES.find((item) => item.key === versionType)?.text || ""}
                                        onOptionSelect={(_, data) => setVersionType(Number(data.optionValue) || VERSION_TYPE_MINOR)}
                                    >
                                        {VERSION_TYPES.map((item) => (
                                            <Option key={item.key} value={String(item.key)}>
                                                {item.text}
                                            </Option>
                                        ))}
                                    </Dropdown>
                                </Field>
                                <Field label="Version number">
                                    <Input
                                        className={styles.controlFullWidth}
                                        type="number"
                                        step="0.01"
                                        value={versionNumber}
                                        onChange={(_, data) => setVersionNumber(data.value)}
                                        onBlur={() => setVersionNumber((current) => formatVersionNumber(current))}
                                    />
                                </Field>
                                <Field label="Description">
                                    <Textarea
                                        className={styles.controlFullWidth}
                                        resize="vertical"
                                        rows={5}
                                        value={description}
                                        onChange={(_, data) => setDescription(data.value)}
                                    />
                                </Field>
                            </section>
                            <section className={styles.generalSection}>
                                <Text className={styles.generalSectionTitle}>Applied To</Text>
                                <Field label={appliesToTarget?.label || "Applied To"}>
                                    <Dropdown
                                        className={styles.controlFullWidth}
                                        placeholder={appliesToTarget ? `Select ${appliesToTarget.label.toLowerCase()}` : "No target type"}
                                        selectedOptions={appliesTo?.id ? [appliesTo.id] : []}
                                        value={appliesTo ? getAppliesToOptionText(appliesTo) : ""}
                                        disabled={!appliesToTarget}
                                        onOptionSelect={(_, data) => {
                                            const selected = appliesToOptions.find((item) => item.id === data.optionValue) || null;
                                            setAppliesTo(selected);
                                        }}
                                    >
                                        {appliesToOptions.map((item) => (
                                            <Option key={item.id} value={item.id}>
                                                <span>
                                                    {item.category && (
                                                        <span className={styles.optionGroupText}>{`${item.category} / `}</span>
                                                    )}
                                                    {item.name}
                                                </span>
                                            </Option>
                                        ))}
                                    </Dropdown>
                                </Field>
                            </section>
                        </div>
                    </div>
                ) : activeTab === "contents" ? (
                    <div className={styles.tabPanel}>
                        <div className={styles.contentsLayout}>
                            <div className={styles.contentsColumn}>
                                <div className={styles.contentsColumnHeader}>
                                    <div>
                                        <Text block weight="semibold">Sections</Text>
                                        <Caption1 className={styles.mutedText}>
                                            {`${sectionCount} section${sectionCount === 1 ? "" : "s"}`}
                                        </Caption1>
                                    </div>
                                    <Button
                                        appearance="primary"
                                        icon={<AddRegular />}
                                        disabled={Boolean(draftSection || draftItem)}
                                        onClick={() => startNewSection(null)}
                                    >
                                        New Section
                                    </Button>
                                </div>
                                <div className={styles.contentsColumnBody}>
                                    {isDraggingChildSection && (
                                        <div
                                            className={[
                                                styles.promoteDropZone,
                                                dragOverTarget?.type === "topLevelSections" ? styles.activePromoteDropZone : "",
                                            ].filter(Boolean).join(" ")}
                                            onDragOver={(event) => {
                                                event.preventDefault();
                                                setDragOverTarget({ type: "topLevelSections" });
                                            }}
                                            onDragLeave={() => {
                                                if (dragOverTarget?.type === "topLevelSections") setDragOverTarget(null);
                                            }}
                                            onDrop={(event) => {
                                                event.preventDefault();
                                                handlePromoteSectionDrop();
                                            }}
                                        >
                                            <Text weight="semibold">Drop here to make this a top-level section</Text>
                                        </div>
                                    )}
                                    {sections.map((section) => renderSectionRow(section))}
                                    {draftSection?.parentId === null && renderDraftSectionRow(0)}
                                    {!flattenedSections.length && !draftSection && (
                                        <div className={styles.contentsPlaceholder}>
                                            <Text weight="semibold">Create your first section</Text>
                                        </div>
                                    )}
                                </div>
                            </div>
                            <div className={styles.contentsColumn}>
                                <div className={styles.contentsColumnHeader}>
                                    <div>
                                        {selectedSectionPath.length ? (
                                            <div className={styles.sectionPathTitle}>
                                                {selectedSectionPath.map((section, index) => (
                                                    <React.Fragment key={section.id}>
                                                        {index > 0 && <Text className={styles.mutedText}>{">"}</Text>}
                                                        <Text
                                                            weight={index === selectedSectionPath.length - 1 ? "semibold" : "regular"}
                                                            className={index === selectedSectionPath.length - 1 ? styles.sectionPathCurrent : styles.sectionPathPart}
                                                        >
                                                            {section.name || "Untitled section"}
                                                        </Text>
                                                    </React.Fragment>
                                                ))}
                                            </div>
                                        ) : (
                                            <Text block weight="semibold">Select a section</Text>
                                        )}
                                        {selectedSection && (
                                            <Caption1 className={styles.mutedText}>
                                                {selectedSectionHasChildren
                                                    ? "Contains child sections"
                                                    : `${selectedSection.items.length} item${selectedSection.items.length === 1 ? "" : "s"}`}
                                            </Caption1>
                                        )}
                                    </div>
                                    <div className={styles.contentsActions}>
                                        {selectedSection && canAddChildSection && (
                                            <Button
                                                icon={<AddRegular />}
                                                disabled={Boolean(draftSection || draftItem)}
                                                onClick={() => startNewSection(selectedSection.id)}
                                            >
                                                New Child Section
                                            </Button>
                                        )}
                                        {selectedSection && !selectedSectionHasChildren && (
                                            <Button
                                                appearance="primary"
                                                icon={<AddRegular />}
                                                disabled={Boolean(draftSection || draftItem)}
                                                onClick={() => startNewItem(selectedSection.id)}
                                            >
                                                New Item
                                            </Button>
                                        )}
                                    </div>
                                </div>
                                <div className={styles.itemWorkspace}>
                                    {!selectedSection ? (
                                        <div className={styles.contentsPlaceholder}>
                                            <Text weight="semibold">Select or create a section</Text>
                                        </div>
                                    ) : selectedSectionHasChildren ? (
                                        <div className={styles.contentsPlaceholder}>
                                            <Text weight="semibold">Items cannot be added to a parent section.</Text>
                                        </div>
                                    ) : (
                                        <div className={styles.itemList}>
                                            {selectedSection.items.map((item) => (
                                                draftItem?.itemId === item.id ? (
                                                    <React.Fragment key={item.id}>{renderDraftItemRow()}</React.Fragment>
                                                ) : (
                                                    <div
                                                        className={[
                                                            styles.itemRow,
                                                            draggedItem?.type === "item" && draggedItem.id === item.id ? styles.draggingRow : "",
                                                            dragOverTarget?.type === "item" && dragOverTarget.id === item.id ? styles.dropBeforeRow : "",
                                                        ].filter(Boolean).join(" ")}
                                                        key={item.id}
                                                        draggable
                                                        onClick={() => startEditItem(selectedSection.id, item)}
                                                        onDragStart={(event) => {
                                                            event.dataTransfer.effectAllowed = "move";
                                                            event.dataTransfer.setData("text/plain", item.id);
                                                            setDraggedItem({ type: "item", id: item.id, sectionId: selectedSection.id });
                                                        }}
                                                        onDragOver={(event) => {
                                                            if (!canDropItemOnTarget(item)) {
                                                                if (dragOverTarget?.type === "item" && dragOverTarget.id === item.id) setDragOverTarget(null);
                                                                return;
                                                            }
                                                            event.preventDefault();
                                                            setDragOverTarget({ type: "item", id: item.id });
                                                        }}
                                                        onDrop={(event) => {
                                                            event.preventDefault();
                                                            handleItemDrop(item);
                                                        }}
                                                        onDragLeave={() => {
                                                            if (dragOverTarget?.type === "item" && dragOverTarget.id === item.id) setDragOverTarget(null);
                                                        }}
                                                        onDragEnd={() => {
                                                            setDraggedItem(null);
                                                            setDragOverTarget(null);
                                                        }}
                                                    >
                                                        <div className={styles.itemReadOnlyText}>
                                                            <Text weight="semibold">{item.name || "Untitled item"}</Text>
                                                            {item.description && (
                                                                <Caption1 className={styles.mutedText}>{item.description}</Caption1>
                                                            )}
                                                        </div>
                                                        <div className={styles.rowActions}>
                                                            {item.quantity !== null && item.quantity !== undefined && (
                                                                <Caption1 className={styles.mutedText}>{`Qty ${item.quantity}`}</Caption1>
                                                            )}
                                                            <Button
                                                                aria-label="Delete item"
                                                                appearance="subtle"
                                                                icon={<DeleteRegular />}
                                                                onClick={(event) => {
                                                                    event.stopPropagation();
                                                                    requestDeleteItem(selectedSection.id, item);
                                                                }}
                                                            />
                                                        </div>
                                                    </div>
                                                )
                                            ))}
                                            {draftItem?.sectionId === selectedSection.id && !draftItem.itemId && renderDraftItemRow()}
                                            {!selectedSection.items.length && draftItem?.sectionId !== selectedSection.id && (
                                                <div className={styles.contentsPlaceholder}>
                                                    <Text weight="semibold">Create the first checklist item for this section.</Text>
                                                </div>
                                            )}
                                        </div>
                                    )}
                                </div>
                            </div>
                        </div>
                    </div>
                ) : (
                    <div className={styles.tabPanel}>
                        <div className={styles.optionsList}>
                            {options.map((option) => {
                                const definition = CHECKLIST_OPTION_DEFINITIONS.find(
                                    (candidate) => candidate.key === option.key
                                );
                                if (!definition) return null;

                                return (
                                    <div className={styles.optionRow} key={option.key}>
                                        <div className={styles.optionLabel}>
                                            <Text weight="semibold">{definition.label}</Text>
                                            <Text className={styles.optionDescription}>{definition.description}</Text>
                                        </div>
                                        {definition.type === "number" ? (
                                            <Input
                                                type="number"
                                                min={1}
                                                value={String(option.value || 1)}
                                                onChange={(_, data) =>
                                                    updateOption(option.key, Math.max(1, Number(data.value) || 1))
                                                }
                                                style={{ width: 96 }}
                                            />
                                        ) : (
                                            <Checkbox
                                                checked={Boolean(option.value)}
                                                onChange={(_, data) => updateOption(option.key, Boolean(data.checked))}
                                            />
                                        )}
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                )}
            </div>
            <Dialog
                open={Boolean(pendingSectionPromotion)}
                onOpenChange={(_, data) => {
                    if (!data.open) setPendingSectionPromotion(null);
                }}
            >
                <DialogSurface>
                    <DialogBody>
                        <DialogTitle>Make section top level?</DialogTitle>
                        <DialogContent>
                            <Text>
                                {`Move "${pendingSectionPromotion?.sectionName || "this section"}" out from "${pendingSectionPromotion?.parentName || "its parent section"}" and make it a top-level section?`}
                            </Text>
                        </DialogContent>
                        <DialogActions>
                            <Button appearance="secondary" onClick={() => setPendingSectionPromotion(null)}>
                                Cancel
                            </Button>
                            <Button appearance="primary" onClick={confirmSectionPromotion}>
                                Confirm
                            </Button>
                        </DialogActions>
                    </DialogBody>
                </DialogSurface>
            </Dialog>
            <Dialog
                open={Boolean(pendingDelete)}
                onOpenChange={(_, data) => {
                    if (!data.open) setPendingDelete(null);
                }}
            >
                <DialogSurface>
                    <DialogBody>
                        <DialogTitle>
                            {pendingDelete?.type === "item" ? "Delete checklist item?" : "Delete section?"}
                        </DialogTitle>
                        <DialogContent>
                            <Text>
                                {pendingDelete?.type === "item"
                                    ? `Delete "${pendingDelete.name}"?`
                                    : `Delete "${pendingDelete?.name || "this section"}" and all sections/items inside it?`}
                            </Text>
                        </DialogContent>
                        <DialogActions>
                            <Button appearance="secondary" onClick={() => setPendingDelete(null)}>
                                Cancel
                            </Button>
                            <Button appearance="primary" onClick={confirmDelete}>
                                Delete
                            </Button>
                        </DialogActions>
                    </DialogBody>
                </DialogSurface>
            </Dialog>
        </div>
    );
}

export default GeneratedComponent;
