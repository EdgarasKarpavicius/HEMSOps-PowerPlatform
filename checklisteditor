    const moveSectionHighlight = (direction: 1 | -1) => {
        if (!visibleSections.length) return;
        const currentIndex = visibleSections.findIndex(({ section }) => section.id === highlightedSectionId);
        const nextIndex =
            currentIndex < 0
                ? 0
                : Math.min(visibleSections.length - 1, Math.max(0, currentIndex + direction));
        setKeyboardPane("sections");
        setHighlightedSectionId(visibleSections[nextIndex].section.id);
        setSelectedItemId("");
    };
    const moveItemHighlight = (direction: 1 | -1) => {
        if (!selectedSection?.items.length) return;
        const currentIndex = selectedSection.items.findIndex((item) => item.id === selectedItemId);
